class Camera:
    def __init__(self, world_width):
        self.offset_x = 0
        self.world_width = world_width

    def update(self, player):
        target = player.rect.centerx - WIDTH // 3
        self.offset_x = max(0, min(target, self.world_width - WIDTH))

    def apply(self, rect):
        return pygame.Rect(rect.x - self.offset_x, rect.y, rect.width, rect.height)


class GameObject(ABC):
    def __init__(self, image, x, y):
        self.image = image
        self.rect = self.image.get_rect(topleft=(x, y))

    @abstractmethod
    def draw(self, surface, camera):
        pass



class Enemy(GameObject):
    def __init__(self, image, x, y, left_b, right_b, speed):
        super().__init__(image, x, y)
        self.speed = speed
        self.left_bound = left_b
        self.right_bound = right_b

    def move(self, pipes=None):
        self.rect.x += self.speed
        if self.rect.x <= self.left_bound or self.rect.x >= self.right_bound:
            self.speed *= -1

    def hit_player(self, player):
        if not player.invincible and player.rect.colliderect(self.rect):
            player.lives -= 1

            if player.lives > 0:
                sound_nabrak.play()
            player.invincible = True
            player.invincible_timer = 90
            player.rect.x = 100
            player.rect.y = GROUND_Y - 80

    def draw(self, surface, camera):
        img = self.image if self.speed > 0 else pygame.transform.flip(self.image, True, False)
        surface.blit(img, camera.apply(self.rect))


class Item(GameObject):
    def __init__(self, image, x, y):
        super().__init__(image, x, y)
        self.used = False

    @abstractmethod
    def collect(self, player):
        pass

    def is_used(self):
        return self.used

class Player:
    def __init__(self, x, y, lives=3):

        self.animations = {
            "idle": MARIO_IDLE,
            "walk": MARIO_WALK,
            "jump": MARIO_JUMP
        }

        self.state = "idle"
        self.frame = 0
        self.animation_speed = 0.15

        self.image = self.animations["idle"][0]
        self.rect = self.image.get_rect(topleft=(x, y))
        self.speed = 5
        self.jump = False
        self.jump_power = 16
        self.gravity = 0.6
        self.velocity_y = 0
        self.lives = lives
        self.__score = 0
        self.invincible = False
        self.invincible_timer = 0
        self.facing_right = True

    def get_score(self):
        return self.__score

    def add_score(self, amount):
        if amount > 0:
            self.__score += amount

    def animate(self):
        self.frame += self.animation_speed

        if self.frame >= len(self.animations[self.state]):
            self.frame = 0

        self.image = self.animations[self.state][int(self.frame)]


    def update(self, platforms):
        self.velocity_y += self.gravity
        self.rect.y += self.velocity_y

        if self.invincible:
            self.invincible_timer -= 1
            if self.invincible_timer <= 0:
                self.invincible = False

        for plat in platforms:
            if self.rect.colliderect(plat.rect):
                if self.velocity_y > 0 and self.rect.bottom - self.velocity_y <= plat.rect.top + 5:
                    self.rect.bottom = plat.rect.top
                    self.jump = False
                    self.velocity_y = 0
                elif self.velocity_y < 0 and self.rect.top - self.velocity_y >= plat.rect.bottom - 5:
                    self.rect.top = plat.rect.bottom
                    self.velocity_y = 0

        if self.rect.y > HEIGHT + 50:
            self.lives -= 1
            self.rect.x = 90
            self.rect.y = GROUND_Y - 85

        self.animate()

    def move(self, platforms, world_width):
        keys = pygame.key.get_pressed()
        moving = False

        if keys[pygame.K_LEFT]:
            self.rect.x -= self.speed
            self.facing_right = False
            moving = True
            for plat in platforms:
                if self.rect.colliderect(plat.rect):
                    self.rect.left = plat.rect.right

        if keys[pygame.K_RIGHT]:
            self.rect.x += self.speed
            self.facing_right = True
            moving = True
            for plat in platforms:
                if self.rect.colliderect(plat.rect):
                    self.rect.right = plat.rect.left

        if not self.jump and (keys[pygame.K_SPACE] or keys[pygame.K_UP]):
            self.jump = True
            self.velocity_y = -self.jump_power

        if self.jump:
            self.state = "jump"
        elif moving:
            self.state = "walk"
        else:
            self.state = "idle"

        self.rect.x = max(0, min(self.rect.x, world_width - self.rect.width))

    def draw(self, surface, camera):
        if self.invincible and self.invincible_timer % 6 < 3:
            return
        img = self.image if self.facing_right else pygame.transform.flip(self.image, True, False)
        surface.blit(img, camera.apply(self.rect))

class Ground:
    GROUND_H = 75

    def __init__(self, world_width):
        tile_src = pygame.image.load("img/ground.png")
        tile_w = tile_src.get_width()
        tile_h = tile_src.get_height()
        scale_ratio = self.GROUND_H / tile_h
        tile_scaled_w = max(1, int(tile_w * scale_ratio))
        tile_scaled = pygame.transform.scale(tile_src, (tile_scaled_w, self.GROUND_H))

        self.image = pygame.Surface((world_width, self.GROUND_H), pygame.SRCALPHA)
        for x in range(0, world_width, tile_scaled_w):
            self.image.blit(tile_scaled, (x, 0))

        self.rect = pygame.Rect(0, HEIGHT - self.GROUND_H, world_width, self.GROUND_H)

    def draw(self, surface, camera):
        surface.blit(self.image, camera.apply(self.rect))


