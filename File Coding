    screen.blit(coin_text, (20, 10))

    for i in range(player.lives):
        screen.blit(star, (WIDTH - 50 - (i * 40), 5))

def overlay(text, color, sub="", image=None):
    surf = pygame.Surface((WIDTH, HEIGHT))
    surf.fill((0, 0, 0))
    surf.set_alpha(170)
    screen.blit(surf, (0, 0))

    center_x = WIDTH // 2
    center_y = HEIGHT // 2

    if image:
        img_x = center_x - image.get_width() // 2
        img_y = center_y - image.get_height() // 2 - 40
        screen.blit(image, (img_x, img_y))

    if text:
        t = font_big.render(text, True, color)
        screen.blit(t, (center_x - t.get_width() // 2, center_y + 80))

    if sub:
        s = font_small.render(sub, True, RED)
        screen.blit(s, (center_x - s.get_width() // 2, center_y))

