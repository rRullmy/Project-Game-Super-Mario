class Coin(Item):
    def __init__(self, x, y):
        super().__init__(COIN, x, y)

    def collect(self, player, bonus=1):
        if not self.used and player.rect.colliderect(self.rect):
            self.used = True
            player.add_score(bonus)
            sound_coin.play()

    def draw(self, surface, camera):
        if not self.used:
            surface.blit(self.image, camera.apply(self.rect))


class Mushroom(Item):
    def __init__(self, x, y, left_b=None, right_b=None, speed=2):
        super().__init__(mushroom_img, x, y)

        self.speed = speed
        self.left_bound = left_b if left_b is not None else max(0, x - 200)
        self.right_bound = right_b if right_b is not None else x + 200

    def move(self, pipes):
        if self.used:
            return
        self.rect.x += self.speed
        if self.rect.x <= self.left_bound or self.rect.x >= self.right_bound:
            self.speed *= -1
        for pipe in pipes:
            if self.rect.colliderect(pipe.rect):
                if self.speed > 0:
                    self.rect.right = pipe.rect.left
                else:
                    self.rect.left = pipe.rect.right
                self.speed *= -1
                break

    def heal(self, player):
        if not self.used and player.rect.colliderect(self.rect):
            player.lives += 1
            self.used = True

    def draw(self, surface, camera):
        if not self.used:
            img = self.image if self.speed > 0 else pygame.transform.flip(self.image, True, False)
            surface.blit(img, camera.apply(self.rect))

    def collect(self, player):
        if not self.used and player.rect.colliderect(self.rect):
            player.lives += 1
            self.used = True

class Alien(Enemy):
    def __init__(self, x, y, left_b, right_b, speed=3):
        super().__init__(alien_img, x, y, left_b, right_b, speed)

    def move(self, pipes=None):
        self.rect.x += self.speed
        if self.rect.x <= self.left_bound or self.rect.x >= self.right_bound:
            self.speed *= -1
        for pipe in pipes:
            if self.rect.colliderect(pipe.rect):
                if self.speed > 0:
                    self.rect.right = pipe.rect.left
                else:
                    self.rect.left = pipe.rect.right
                self.speed *= -1
                break


