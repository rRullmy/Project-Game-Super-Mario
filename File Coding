def start_game(difficulty):
    global state
    pygame.mixer.music.load("img/soundmain.mp3")
    pygame.mixer.music.play(-1)

    ground, platforms, pipes, blocks, coins, mushrooms, aliens, meteors, houses = setup_level(difficulty)

    player = Player(100, GROUND_Y - 80)
    camera = Camera(WORLD_WIDTH)
    game_over = False
    gameover_played = False
    level_clear = False
    bg_tile_w = bg.get_width()

    while True:
        clock.tick(60)

        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                pygame.quit()
                sys.exit()

            if event.type == pygame.MOUSEBUTTONDOWN:
                sound_click.play()
                if game_over or level_clear:
                    if play_again_rect.collidepoint(event.pos):
                        start_game(difficulty)
                        return
                    elif exit_rect.collidepoint(event.pos):
                        state = "menu_awal"

                        pygame.mixer.music.stop()
                        pygame.mixer.music.load("img/soundbegin.mp3")
                        pygame.mixer.music.play(-1)

                        return

        if not game_over and not level_clear:
            player.move(platforms, WORLD_WIDTH)
            player.update(platforms)
            camera.update(player)

            for alien in aliens:
                alien.move(pipes)
                alien.hit_player(player)

            for coin in coins:
                coin.collect(player)

            for mushroom in mushrooms:
                mushroom.move(pipes)
                mushroom.collect(player)

            for meteor in meteors:
                meteor.move()
                meteor.hit_player(player)

            if player.lives <= 0:
                game_over = True

                if not gameover_played:
                    pygame.mixer.music.stop()
                    sound_kalah.play()
                    gameover_played = True

            if player.rect.colliderect(houses.rect):
                pygame.mixer.music.stop()
                pygame.mixer.stop()
                sound_menang.play()
                level_clear = True

        screen.fill((100, 149, 237))
        num_tiles = (WIDTH // bg_tile_w) + 2
        start_tile = int(camera.offset_x // bg_tile_w)
        for i in range(start_tile, start_tile + num_tiles + 1):
            x_pos = i * bg_tile_w - camera.offset_x
            screen.blit(bg, (x_pos, 40))

        ground.draw(screen, camera)

        for plat in platforms:
            if plat is not ground:
                plat.draw(screen, camera)

        for coin in coins: coin.draw(screen, camera)
        for mushroom in mushrooms: mushroom.draw(screen, camera)
        for alien in aliens: alien.draw(screen, camera)
        for meteor in meteors: meteor.draw(screen, camera)

        houses.draw(screen, camera)

        player.draw(screen, camera)
        draw_hud(player)

        if game_over:
            overlay("", RED, "", gameover)
            screen.blit(playagain, play_again_rect)
            screen.blit(exit_png, exit_rect)
        elif level_clear:
            overlay("", GREEN, "", youwin)
            screen.blit(playagain, play_again_rect)
            screen.blit(exit_png, exit_rect)

        pygame.display.update()


while True:
