        if ev.type == pygame.QUIT:
            pygame.quit()
            sys.exit()

        if ev.type == pygame.MOUSEBUTTONDOWN:

            if state == "menu_awal":
                if play_btn.collidepoint(ev.pos):
                    sound_click.play()
                    state = "pilih_level"

            elif state == "pilih_level":
                if easy_btn.collidepoint(ev.pos):
                    sound_click.play()
                    start_game(1)
